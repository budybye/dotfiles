#!/usr/bin/env bash
set -eu

# chezmoi apply が完了したら最後に実行される
echo "wish.sh"
echo "--------------------------------"
echo "Chezmoi apply completed!!"
echo "USER: $(whoami)"
echo "SHELL: ${SHELL}"
uname -a
echo "--------------------------------"
echo "PATH ..."
# 重複したPATHを削除
if command -v awk > /dev/null 2>&1; then
    export PATH="$(printf %s "${PATH}" | awk -v RS=: -v ORS=: '!arr[$0]++')"
fi
echo "${PATH}" | tr ':' '\n'
echo "--------------------------------"
echo "pwd: $(pwd)"
echo "SourceDir: {{ .chezmoi.sourceDir }}"
tree -L 3 {{ .chezmoi.sourceDir }}
echo "--------------------------------"
echo "${HOME}"
ls -la "${HOME}"
echo "--------------------------------"
echo "${HOME}/data"
[ -d "${HOME}/data" ] && ls -la "${HOME}/data" || echo "data not found"
echo "--------------------------------"
tree -L 3 "${HOME}/.config" || ls -la "${HOME}/.config" || echo ".config not found."
echo "--------------------------------"
echo "${HOME}/.ssh"
[ -d "${HOME}/.ssh" ] && ls -la "${HOME}/.ssh" || echo ".ssh not found"
echo "--------------------------------"
echo "${HOME}/.local/bin"
ls -la "${HOME}/.local/bin"
echo "--------------------------------"
tree -L 3 "${HOME}/.local/share"
echo "--------------------------------"
{ command -v tree >/dev/null 2>&1 && tree "${HOME}/Music/riddim"; } || ls -la "${HOME}/Music" || echo "Music not found."
echo "--------------------------------"

{{ if eq .chezmoi.os "linux" }}

{ [ -d "${HOME}/.local/share/themes" ] && tree -L 2 "${HOME}/.local/share/themes"; } || echo "themes not found."
echo "--------------------------------"
{ [ -d "${HOME}/.local/share/fonts" ] && tree -L 2 "${HOME}/.local/share/fonts"; } || echo "fonts not found."
echo "--------------------------------"
{ [ -d "${HOME}/.local/share/icons" ] && tree -L 2 "${HOME}/.local/share/icons"; } || echo "icons not found."
echo "--------------------------------"

{{ end }}

# ${HOME}/dotfiles が存在しない場合はシンボリックリンクを作成する
if [ -d "${HOME}/dotfiles" ]; then
    echo "Dotfiles already exists."
else
    echo "Create symlink..."
    ln -sf "{{ .chezmoi.sourceDir }}" "${HOME}/dotfiles"
fi
ls -la "${HOME}/dotfiles"
echo "--------------------------------"

{{/* git の user.conf を対話型にする */}}
{{ if eq .chezmoi.hostname "589" }}

echo 'git userconf update ? (y/n)'
read ans
if [ "$ans" = "y" ] || [ "$ans" = "Y" ]; then
    vim "${HOME}/.config/git/user.conf"
fi
cat ~/.config/git/user.conf
echo "--------------------------------"

{{ end }}

if command -v chezmoi > /dev/null 2>&1; then
    chezmoi data
    echo "--------------------------------"
    chezmoi doctor
    echo "--------------------------------"
    chezmoi ignored
    echo "--------------------------------"
    echo 'Chezmoi Apply done!!'
    echo "https://github.com/budybye/dotfiles"
fi

if command -v fastfetch > /dev/null 2>&1; then
    fastfetch
fi

if command -v xrp > /dev/null 2>&1; then
    xrp
fi
