#!/usr/bin/env bash
set -eu

echo "activate.sh"
echo "--------------------------------"
echo "Welcome to ${USER:-$(whoami)} dotfiles!!"
echo "sourceDir is {{ .chezmoi.sourceDir }}"
echo "user is $(whoami)"
echo "OS info ..."
uname -mars
echo "SHELL is $SHELL"
echo "--------------------------------"

# .env の確認と作成
echo ".env && ENVIRONMENT checking..."
if [ -f {{ .chezmoi.sourceDir }}/.env ]; then
    cat {{ .chezmoi.sourceDir }}/.env
    mise set || echo "mise set failed."
else
    echo "no {{ .chezmoi.sourceDir }}/.env file"
fi
echo "--------------------------------"
env
echo "--------------------------------"

# SSH の設定

{{ if ne .ssh false }}

echo "SSH key ..."
{ [ -r /etc/ssh/sshd_config ] && cat /etc/ssh/sshd_config; } || echo "sshd_config not readable (permission denied)"
echo "--------------------------------"
if [ -d ~/.ssh ]; then
    chmod 700 ~/.ssh
    if [ -f ~/.ssh/id_ed25519 ]; then
        chmod 600 ~/.ssh/id_ed25519
    else
        echo "no ~/.ssh/id_ed25519 file"
    fi

    echo "authorized_keys..."
    if [ -f ~/.ssh/authorized_keys ]; then
        cat ~/.ssh/authorized_keys
        chmod 600 ~/.ssh/authorized_keys
    else
        echo "no ~/.ssh/authorized_keys file"
    fi
    echo "--------------------------------"

    ls -la ~/.ssh
    echo "SSH key pub ..."
    if [ -f ~/.ssh/id_ed25519.pub ]; then
        chmod 644 ~/.ssh/id_ed25519.pub
        cat ~/.ssh/id_ed25519.pub
    else
        echo "no ~/.ssh/id_ed25519.pub file"
    fi
    echo "--------------------------------"
    echo "SSH Config ..."
    if [ -f ~/.ssh/config ]; then
        cat ~/.ssh/config
    else
        echo "no ~/.ssh/config file"
    fi
    echo "--------------------------------"
else
    echo "no ~/.ssh directory"
fi
echo "--------------------------------"

{{ else }}

echo "SSH key not set."
echo "--------------------------------"

{{ end }}

# git の設定

{{ if ne .github false }}

echo "github yes"
echo "git config ..."
ls -la ~/.config/git || echo "git config dir not found."
echo "--------------------------------"
cat ~/.config/git/user.conf || echo "user.conf not found."
echo "--------------------------------"
echo "git config user.name"
git config user.name || echo "git user.name not set."
echo "git config user.email"
git config user.email || echo "git user.email not set."
echo "--------------------------------"
cat ~/.config/git/config || echo "git config not found."
echo "--------------------------------"
cat ~/.config/git/commit.template || echo "commit.template not found."
git config --global commit.template "${HOME}/.config/git/commit.template" || echo "commit.template set failed."
echo "--------------------------------"

{{ else }}

echo "github no"
echo "--------------------------------"

{{ end }}

# bitwarden の設定

{{ if ne .bitwarden false }}

echo "bitwarden yes"
echo "--------------------------------"

{{ else }}

echo "bitwarden no"
echo "--------------------------------"

{{ end }}

# age の設定

{{ if ne .age false }}

echo "age yes"
echo "--------------------------------"

{{ else }}

echo "age no"
echo "--------------------------------"

{{ end }}

# Music の確認
if [ -f ~/Music/riddim ]; then
    ls ~/Music/riddim
else
    echo "$HOME/Music/riddim not found."
fi
echo "--------------------------------"
