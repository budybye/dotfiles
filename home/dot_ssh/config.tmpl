HashKnownHosts no

{{- if eq .chezmoi.os "darwin" }}

Host *
  AddKeysToAgent yes
  UseKeychain yes
{{- end }}

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

Host ubuntu
  HostName vm.local
  User ubuntu
  IdentityFile ~/.ssh/id_ed25519
  ServerAliveInterval 60

Host budybye
  HostName vm.local
  User budybye
  IdentityFile ~/.ssh/id_ed25519
  ServerAliveInterval 60
