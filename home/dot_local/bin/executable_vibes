#!/usr/bin/env bash

set -eu

ensure_claude_md() {
  if [ -f ./CLAUDE.md ]; then
    return 0
  fi

  echo "CLAUDE.md not found"
  if [ -f ./AGENTS.md ]; then
    ln -sf ./AGENTS.md ./CLAUDE.md
    echo "CLAUDE.md created"
  else
    echo "AGENTS.md not found"
  fi
}

show_agents_dir() {
  if [ -d "${1}" ]; then
    ls -la "${1}"
  else
    echo "${1}directory not found"
  fi
}

# style: labeled (default) | raw
report_tool() {
  local cmd="$1"
  local style="${2:-labeled}"

  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "${cmd} not found"
    return
  fi

  case "$style" in
    raw) "$cmd" --version ;;
    *) echo "${cmd} $("$cmd" --version)" ;;
  esac
}

ensure_claude_md
show_agents_dir "${HOME}/.agents"
show_agents_dir "./.agents"

report_tool claude
report_tool gemini
report_tool codex raw
report_tool cursor-agent
report_tool opencode
report_tool pi
