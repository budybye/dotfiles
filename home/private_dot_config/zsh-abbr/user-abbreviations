# シェル操作
abbr q='exit'
abbr c='clear'
abbr rl='source ~/.zshenv'
abbr reload='exec $SHELL -l'

# ナビゲーション
abbr hh='cd ~'

# システム情報
abbr www='ps aux'
abbr now='date +%Y%m%d%H%M%S'
abbr sysinfo='uname -a && uptime'
abbr meminfo='free -h 2>/dev/null || vm_stat'
abbr diskinfo='df -h'

# 検索・フィルタ
abbr hg='history | grep'
abbr vv='env | grep'

# 区切り線
abbr br='echo -------------------------------------'

# シェルパフォーマンス計測
abbr opi='for i in {1..3}; do time $SHELL -ic exit; done'
abbr oppi='for i in {1..3}; do time $SHELL -lc exit; done && exec $SHELL'

