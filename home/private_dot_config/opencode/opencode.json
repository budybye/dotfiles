{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["docs/*.md", "test/*.md"],
  "provider": {
    "sakura": {
      "name": "Sakura AI",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gpt-oss-120b": {
          "name": "Chappy"
        }
      },
      "options": {
        "baseURL": "https://api.ai.sakura.ad.jp/v1"
      }
    }
  },
  "autoupdate": true,
  "server": {
    "port": 7788
  },
  "disabled_providers": [],
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "mcp": {},
  "compaction": {}
}
