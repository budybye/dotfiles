{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "docs/design.md",
    "docs/directory.md",
    "docs/go-template.md",
    "docs/problems.md",
    "docs/reference.md",
    "docs/requiremenrs.md",
    "docs/security.md",
    "docs/tasks.md",
    "docs/tesch.md",
    "tests/*.md",
  ],
  "provider": {
    "anthropic": {
      "models": {
        "anthropic/claude-sonnet-4": {},
      },
      "options": {
        "baseURL": "https://claude.589.workers.dev",
      },
    },
    "cloudflare-ai-gateway": {
      "models": {
        "anthropic/claude-sonnet-4": {},
      },
    },
    "sakura": {
      "name": "Sakura AI Engine",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gpt-oss-120b": {
          "name": "Chappy",
        },
      },
      "options": {
        "baseURL": "https://api.ai.sakura.ad.jp/v1",
      },
    },
  },
  "autoupdate": true,
  "server": {
    "port": 7788,
  },
  "disabled_providers": [],
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"],
  },
  "mcp": {
    "cloudflare": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "enabled": true,
    },
    "cloudflare-docs": {
      "type": "remote",
      "url": "https://docs.mcp.cloudflare.com/mcp",
      "enabled": true,
    },
  },
  "compaction": {},
}
