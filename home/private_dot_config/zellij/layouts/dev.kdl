// タブ1: 4ペイン
// タブ2: 4ペイン
// タブ3: 2ペイン

layout {
    // デフォルトタブテンプレート
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }

        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="101" {
        pane split_direction="vertical" {
            pane split_direction="horizontal" {
                pane {
                    name "home"
                    cwd "~"
                    command "btm"
                }
                pane {
                    name "dotfiles"
                    cwd "~/dotfiles"
                    command "fastfetch"
                    focus true
                }
            }
            pane split_direction="horizontal" {
                pane {
                    name "ncmpcpp"
                    cwd "~/Music"
                    command "ncmpcpp"
                }
                pane {
                    name "Data"
                    cwd "~/data"
                    command "cat"
                    args "./cat.txt"
                }
            }
        }
    }

    tab name="Dev" {
        pane split_direction="vertical" {
            pane split_direction="horizontal" {
                pane {
                    name "dev1"
                    cwd "~/Developer/4life"
                }
                pane {
                    name "dev2"
                    cwd "~/Developer/workers"
                }
            }
            pane split_direction="horizontal" {
                pane {
                    name "dev3"
                    cwd "~/Developer/rivet"
                }
                pane {
                    name "dev4"
                    cwd "~/Developer/project"
                    focus true
                }
            }
        }
    }

    tab name="edit" {
        pane split_direction="vertical" {
            pane {
                name "dev"
                cwd "~/Developer"
                focus true
            }
            pane {
                name "docs"
                cwd "~/Developer/docs"
                command "mpd"
                args "~/.config/mpd/mpd.conf"
            }
        }
    }

    tab name="docker" {
        pane {
            name "lazydocker"
            cwd "~/Developer"
            command "lazydocker"
        }
    }

    tab name="xrp" {
        pane {
            name "rippled"
            cwd "~/Developer/rippled"
            command "make"
            args "help"
        }
        pane {
            name "lazyxrp"
            cwd "~/Developer/rust/lazyxrp"
            command "cargo"
            args "clippy"
        }
    }
}
