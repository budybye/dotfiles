// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
// sakuraAI: https://knowledge.sakura.ad.jp/47768/
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "indent_size": 16.0,
    "default_width": 200.0,
    "dock": "left",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "cursor": {
      "favorite_config_option_values": {
        "model": [
          "default[]",
          "composer-2[fast=true]",
          "claude-opus-4-7[thinking=true,context=300k,effort=xhigh]",
          "gemini-3.1-pro[]",
          "gpt-5.5[context=272k,reasoning=medium,fast=false]",
          "grok-4-20[thinking=true]",
        ],
      },
      "type": "registry",
    },
    "pi-acp": {
      "favorite_models": [
        "cursor/auto",
        "cursor/composer-2-fast",
        "cursor/gemini-3.1-pro",
        "sakura/gpt-oss-120b",
        "sakura/Qwen3-Coder-480B-A35B-Instruct-FP8",
        "openrouter/openai/gpt-oss-120b:free",
        "openrouter/openrouter/free",
        "cloudflare-ai-gateway/workers-ai/@cf/moonshotai/kimi-k2.6",
        "cloudflare-workers-ai/@cf/moonshotai/kimi-k2.6",
        "cursor/grok-4-20-thinking",
        "opencode-go/glm-5.1",
        "opencode-go/kimi-k2.6",
        "opencode-go/deepseek-v4-pro",
        "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
        "cloudflare-ai-gateway/gpt-5.3-codex",
        "cloudflare-ai-gateway/claude-opus-4-6",
        "cursor/gpt-5.3-codex-spark-preview",
        "cursor/claude-4.6-opus-high-thinking-fast"
      ],
      "type": "registry",
    },
    "opencode": {
      "favorite_config_option_values": {
        "model": [
          "cloudflare-workers-ai/@cf/moonshotai/kimi-k2.6",
          "openrouter/openrouter/free",
          "openrouter/openai/gpt-oss-120b:free",
          "opencode/nemotron-3-super-free/high",
          "openrouter/qwen/qwen3-coder-30b-a3b-instruct"
        ],
      },
      "favorite_models": [
        "cloudflare-workers-ai/@cf/moonshotai/kimi-k2.6",
        "openrouter/openrouter/free",
        "openrouter/openai/gpt-oss-120b:free",
        "opencode/nemotron-3-super-free/high",
      ],
      "type": "registry",
    },
  },
  "context_servers": {
    "mcp-server-repomix": {
      "enabled": false,
      "remote": false,
      "settings": {},
    },
    "mcp-server-playwright": {
      "enabled": false,
      "remote": false,
      "settings": {},
    },
    "mcp-server-context7": {
      "enabled": false,
      "remote": false,
      "settings": {
        "context7_api_key": "",
      },
    },
    "bun-docs-mcp": {
      "enabled": false,
      "remote": false,
      "settings": {},
    },
    "chrome-devtools-mcp-zed": {
      "enabled": false,
      "remote": false,
      "settings": {
        "browser_url": null,
        "ws_endpoint": null,
        "ws_headers": null,
        "auto_connect": null,
        "channel": null,
        "headless": null,
        "isolated": null,
        "user_data_dir": null,
        "viewport": null,
        "executable_path": null,
        "chrome_arg": [],
        "proxy_server": null,
        "accept_insecure_certs": null,
        "category_emulation": null,
        "category_performance": null,
        "category_network": null,
        "log_file": null,
        "extra_args": [],
      },
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "confirm_quit": true,
  "language_models": {
    "opencode": {
      "show_zen_models": false
    },
    "openai_compatible": {
      "sakura": {
        "api_url": "https://api.ai.sakura.ad.jp/v1",
        "available_models": [
          {
            "name": "gpt-oss-120b",
            "display_name": null,
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
        ],
      },
    },
  },
  "agent": {
    "dock": "right",
    "favorite_models": [
      {
        "provider": "sakura",
        "model": "gpt-oss-120b",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "openrouter/free",
        "enable_thinking": true
      },
      {
        "provider": "openrouter",
        "model": "openai/gpt-oss-120b:free",
        "enable_thinking": true
      },
      {
        "provider": "openrouter",
        "model": "nvidia/nemotron-3-super-120b-a12b:free",
        "enable_thinking": true
      },
      {
        "provider": "opencode",
        "model": "go/kimi-k2.6",
        "enable_thinking": false
      },
      {
        "provider": "opencode",
        "model": "go/glm-5.1",
        "enable_thinking": false
      }
    ],
    "default_profile": "write",
    "inline_assistant_model": {
      "provider": "sakura",
      "model": "gpt-oss-120b",
    },
    "default_model": {
      "enable_thinking": false,
      "provider": "sakura",
      "model": "gpt-oss-120b",
    },
    "single_file_review": false,
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": "never",
  },
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "formatter": "auto",
  "ui_font_family": "HackGen35 Console NF",
  "buffer_font_weight": 400.0,
  "buffer_font_family": "HackGen35 Console NF",
  "icon_theme": "Material Icon Theme",
  "base_keymap": "VSCode",
  "ui_font_size": 15.0,
  "buffer_font_size": 16.0,
  "buffer_line_height": "comfortable",
  "theme": {
    "mode": "system",
    "light": "Monokai Pro (CE)",
    "dark": "Kanagawa Dragon - No Italics",
  },
  "edit_predictions": {
    "open_ai_compatible_api": {
      "api_url": "",
    },
    "provider": "zed",
  },
  "terminal": {
    "shell": {
      "with_arguments": {
        "program": "/bin/zsh",
        "args": [],
      },
    },
    "font_size": 12,
    "copy_on_select": true,
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx"],
        "experimental": {
          "classRegex": ["[cls|className]\\s\\:\\=\\s\"([^\"]*)"],
        },
      },
    },
  },
  "languages": {
    "CSS": {
      "language_servers": [
        "tailwindcss-intellisense-css",
        "!vscode-css-language-server",
      ],
    },
  },
}
