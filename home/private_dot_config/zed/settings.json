// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
// sakuraAI: https://knowledge.sakura.ad.jp/47768/
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "pi-acp": {
      "favorite_models": [
        "cursor/auto",
        "sakura/Qwen3-Coder-480B-A35B-Instruct-FP8",
        "sakura/gpt-oss-120b",
        "openrouter/anthropic/claude-opus-4.7",
        "openrouter/anthropic/claude-sonnet-4.6",
        "cloudflare-ai/@cf/moonshotai/kimi-k2.5",
        "cloudflare-ai/@cf/zai-org/glm-4.7-flash",
        "cursor/claude-opus-4-7-xhigh",
        "cursor/composer-2-fast"
      ],
      "type": "registry",
    },
    "claude-acp": {
      "favorite_config_option_values": {
        "model": ["sonnet"],
      },
      "type": "registry",
    },
    "opencode": {
      "favorite_config_option_values": {
        "model": ["opencode/big-pickle/max"],
      },
      "favorite_models": [
        "sakura/gpt-oss-120b",
        "opencode/big-pickle/max",
        "opencode/nemotron-3-super-free/high",
        "cloudflare-workers-ai/@cf/moonshotai/kimi-k2.5",
      ],
      "type": "registry",
    },
  },
  "context_servers": {
    "mcp-server-repomix": {
      "enabled": false,
      "remote": false,
      "settings": {},
    },
    "mcp-server-playwright": {
      "enabled": false,
      "remote": false,
      "settings": {},
    },
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "",
      },
    },
    "bun-docs-mcp": {
      "enabled": false,
      "remote": false,
      "settings": {},
    },
    "chrome-devtools-mcp-zed": {
      "enabled": true,
      "remote": false,
      "settings": {
        "browser_url": null,
        "ws_endpoint": null,
        "ws_headers": null,
        "auto_connect": null,
        "channel": null,
        "headless": null,
        "isolated": null,
        "user_data_dir": null,
        "viewport": null,
        "executable_path": null,
        "chrome_arg": [],
        "proxy_server": null,
        "accept_insecure_certs": null,
        "category_emulation": null,
        "category_performance": null,
        "category_network": null,
        "log_file": null,
        "extra_args": [],
      },
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "confirm_quit": true,
  "language_models": {
    "openai_compatible": {
      "sakura": {
        "api_url": "https://api.ai.sakura.ad.jp/v1",
        "available_models": [
          {
            "name": "gpt-oss-120b",
            "display_name": null,
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
        ],
      },
    },
  },
  "agent": {
    "dock": "right",
    "favorite_models": [
      {
        "provider": "sakura",
        "model": "gpt-oss-120b",
        "enable_thinking": false,
      },
      {
        "provider": "anthropic",
        "model": "claude-opus-4-6-latest",
        "enable_thinking": false,
      },
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-6-latest",
        "enable_thinking": false,
      },
      {
        "provider": "zed.dev",
        "model": "gemini-3.1-pro-preview",
        "enable_thinking": false,
      },
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4-6",
        "enable_thinking": false,
      },
    ],
    "default_profile": "write",
    "inline_assistant_model": {
      "provider": "sakura",
      "model": "gpt-oss-120b",
    },
    "default_model": {
      "enable_thinking": false,
      "provider": "sakura",
      "model": "gpt-oss-120b",
    },
    "single_file_review": false,
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": "never",
  },
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "formatter": "auto",
  "ui_font_family": "HackGen35 Console NF",
  "buffer_font_weight": 400.0,
  "buffer_font_family": "HackGen35 Console NF",
  "icon_theme": "Catppuccin Latte",
  "base_keymap": "VSCode",
  "ui_font_size": 15.0,
  "buffer_font_size": 16.0,
  "buffer_line_height": "comfortable",
  "theme": {
    "mode": "system",
    "light": "Monokai Pro (CE)",
    "dark": "Kanagawa Dragon",
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "terminal": {
    "shell": {
      "with_arguments": {
        "program": "/bin/zsh",
        "args": [],
      },
    },
    "font_size": 12,
    "copy_on_select": true,
  },
}
