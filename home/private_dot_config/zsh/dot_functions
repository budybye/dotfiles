# 重複したPATHを削除
if command -v awk > /dev/null 2>&1; then
    export PATH="$(printf %s "${PATH}" | awk -v RS=: -v ORS=: '!arr[$0]++')"
fi

# ファイル操作（安全系）- 常時透過オーバーライドが必要なため alias で定義
alias mv="mv -i"
alias cp="cp -i"
alias rm="rm -i"
alias mkdir="mkdir -p"

# ドキュメント
alias note="${EDITOR:-vim} ${HOME}/Developer/docs/note.md"
alias docs="cd ${HOME}/Developer/docs"

# git
if command -v git >/dev/null 2>&1 || command -v jj >/dev/null 2>&1; then
    function bit() {
        git add -A
        if [ -z "$1" ]; then
            git commit --allow-empty-message -m ""
        else
            git commit -m "$1"
        fi
        git push origin $(git branch | sed -n -e "s/^\* \(.*\)/\1/p")
    }
fi

if command -v code >/dev/null 2>&1; then
    alias vex="code --list-extensions | jq -R -s 'split(\"\n\")[:-1]' > tmp/extensions.json && diff tmp/extensions.json ${HOME}/.config/Code/extensions.json"
fi

# vim/nvim（フォールバックチェーンが必要なため alias で定義）
if command -v nvim >/dev/null 2>&1; then
    alias v="nvim"
elif command -v vim >/dev/null 2>&1; then
    alias v="vim"
else
    alias v=${EDITOR:-vi}
fi

# ping（関数でデフォルト引数を追加）
if command -v ping >/dev/null 2>&1; then
    function ping() {
        command ping -c 3 ${@:-1.1.1.1}
    }
fi

# ip表示
if command -v ipconfig >/dev/null 2>&1; then
    alias addr="ipconfig getifaddr en0 && wan"
elif command -v ifconfig >/dev/null 2>&1; then
    alias addr="ifconfig en0 inet && wan"
elif command -v ip >/dev/null 2>&1; then
    alias addr="ip addr show en0 && wan"
fi

