    alias arm="arch -arm64 ${SHELL}"
fi

# クリップボード（mac/linux 条件分岐が必要なため alias で定義）
if command -v pbcopy >/dev/null 2>&1; then
    alias cx="pbcopy"
    alias cv="pbpaste"
    alias cb="pbcopy"
elif command -v xsel >/dev/null 2>&1; then
