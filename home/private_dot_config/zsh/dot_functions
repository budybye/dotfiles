# warp-cli（複雑なもの）
if command -v warp-cli >/dev/null 2>&1; then
    alias wpr="warp-cli registration delete && warp-cli --accept-tos registration new"
    alias wpm="warp-cli dns families malware"
    alias wpw="warp-cli mode warp"
    alias warp="wpr && wpm && wpw && warp-cli connect && warp-cli status"
