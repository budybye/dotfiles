# docker（関数・複雑なもの）
if command -v docker >/dev/null 2>&1; then
    function ddd() {
        IMAGE_NAME="${1:-$(date +%Y%m%d%H%M%S)}"
        docker build -t "$IMAGE_NAME" . && docker push "$IMAGE_NAME"
    }
    ARCH=${ARCH:-$(dpkg --print-architecture 2>/dev/null || uname -m)}
    alias dx="docker run --rm -itd --privileged --platform linux/${ARCH} --hostname docker --name ubuntu-dev -p 33389:3389 -p 2222:22 ghcr.io/budybye/ubuntu-dev:main ubuntu ubuntu yes"
fi

if command -v podman >/dev/null 2>&1; then
    alias docker="podman"
fi

# multipass（複雑なもの）
if command -v multipass >/dev/null 2>&1; then
    alias md="mp launch docker -c 4 -m 8G -d 42G --timeout 3600 && mp info docker"
    alias ml="mp launch -n ubuntu -c 4 -m 8G -d 42G --timeout 7200 --cloud-init ${HOME}/dotfiles/cloud-init/multipass.yaml && mp exec ubuntu -- tail -7 /var/log/cloud-init.log"
    alias ms="mp stop ubuntu && mp delete -p ubuntu && mp list"
fi

# brew（複雑なもの）
if command -v brew >/dev/null 2>&1; then
    alias bf="brew bundle --force --file ${HOME}/.config/Brewfile"
    alias bcp="brew autoremove && brew cleanup --prune=all && brew doctor"
    alias bb="bf && brew update && brew upgrade --greedy && bcp"
    function bbb() {
        bb
        dumpfile=${HOME}/.config/homebrew/Brewfile
        if [ -f "${dumpfile}" ]; then
            cp "${dumpfile}" "${dumpfile}.bak"
            rm -f "${dumpfile}"
        fi
        brew bundle dump --file "${dumpfile}"
        cat "${dumpfile}"
    }
fi

