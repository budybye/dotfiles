# cloudflared（複雑なもの）
if command -v cloudflared >/dev/null 2>&1; then
    RDP_HOST="${RDP_HOST:-rdp.tmg-server.com}"
    RDP_PORT="${RDP_PORT:-7777}"
    alias rdp="cloudflared access rdp --hostname \"${RDP_HOST}\" --url localhost:${RDP_PORT}"
    RPI_HOST="${RPI_HOST:-rpi.tmg-server.com}"
    RPI_PORT="${RPI_PORT:-33333}"
    alias rpi="cloudflared access rdp --hostname \"${RPI_HOST}\" --url localhost:${RPI_PORT}"
    SMB_HOST="${SMB_HOST:-data.tmg-server.com}"
    SMB_PORT="${SMB_PORT:-44444}"
    alias smb="cloudflared access smb --hostname \"${SMB_HOST}\" --url localhost:${SMB_PORT}"
fi

# element-desktop
if command -v element-desktop >/dev/null 2>&1; then
    alias ele="element-desktop"
fi

# openssl
if command -v openssl >/dev/null 2>&1; then
    function sec() {
        ENV_FILE="${ENV_FILE:-.env}"
        echo "${@:-SECRET}=$(openssl rand -base64 32)" >> "${ENV_FILE}" && ls
    }
fi

# rq
if command -v rj >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    function rq() {
        API_URL=${1:-${API_URL:-"https://8102.jp/api"}}
        rj "${API_URL}" | jq -r '.data'
    }
fi

# ipfs
if command -v ipfs >/dev/null 2>&1; then
    DATA_DIR="${DATA_DIR:-.}"
    function pin() {
        ipfs add -r -p -q --cid-version 1 "${@:-${DATA_DIR}}"
    }
fi

