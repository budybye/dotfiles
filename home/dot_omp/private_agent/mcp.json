{
  "mcpServers": {
    "context-mode": {
      "type": "stdio",
      "command": "node",
      "args": [
        "/Users/hotmilk/.omp/plugins/node_modules/context-mode/server.bundle.mjs"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
