{
  "defaultProvider": "cursor",
  "defaultModel": "composer-2-fast",
  "defaultThinkingLevel": "medium",
  "thinkingBudgets": {
    "minimal": 1024,
    "low": 4096,
    "medium": 10240,
    "high": 32768
  },
  "theme": "monokai",
  "language": "ja",
  "locale": "ja-JP",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "sessionDir": ".pi/sessions",
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "retryDelay": 3000,
    "maxRetryDelay": 60000
  },
  "shellCommandPrefix": "shopt -s expand_aliases\neval \"$(grep '^alias ' ~/.aliases)\"",
  "npmCommand": [
    "bun"
  ],
  "packages": [
    "git:github.com/badlogic/pi-skills",
    "npm:pi-goal",
    "npm:pi-runline",
    "npm:pi-subagents",
    "npm:pi-mcp-adapter",
    "npm:pi-code-previews",
    "npm:graphify-pi",
    "npm:@haispeed/pi-obsidian",
    "npm:@netandreus/pi-cursor-provider"
  ],
  "extensions": [],
  "prompts": [],
  "skills": [
    "~/.claude/skills",
    "~/.codex/skills",
    "~/.gemini/skills",
    "~/.agentskills",
    "~/.aionui-config/skills"
  ],
  "enableSkillCommands": true,
  "lastChangelogVersion": "0.74.0",
  "enableInstallTelemetry": false,
  "enabledModels": [
    "cloudflare-ai-gateway/gpt-5.3-codex",
    "cloudflare-ai-gateway/claude-opus-4-6",
    "cloudflare-ai-gateway/workers-ai/@cf/moonshotai/kimi-k2.6",
    "cloudflare-workers-ai/@cf/moonshotai/kimi-k2.6",
    "opencode-go/glm-5.1",
    "opencode-go/kimi-k2.6",
    "cursor/auto",
    "cursor/gemini-3.1-pro",
    "cursor/composer-2-fast",
    "cursor/claude-4.6-opus-high-thinking",
    "cursor/gpt-5.3-codex-spark-preview-high",
    "sakura/gpt-oss-120b",
    "sakura/Qwen3-Coder-480B-A35B-Instruct-FP8",
    "openrouter/openrouter/free",
    "openrouter/openai/gpt-oss-120b:free",
    "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
    "anthropic/claude-opus-4-6"
  ]
}