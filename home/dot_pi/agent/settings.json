{
  "enabledModels": ["claude-*", "gpt-*", "Qwen*"],
  "defaultProvider": "sakura",
  "defaultModel": "Qwen3-Coder-480B-A35B-Instruct-FP8",
  "defaultThinkingLevel": "medium",
  "thinkingBudgets": {
    "minimal": 1024,
    "low": 4096,
    "medium": 10240,
    "high": 32768
  },
  "theme": "monokai",
  "language": "ja",
  "locale": "ja-JP",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "sessionDir": ".pi/sessions",
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "retryDelay": 3000,
    "maxRetryDelay": 60000
  },
  "packages": ["pi-skills", "npm:pi-subagents"],
  "extensions": [],
  "prompts": [],
  "skills": ["~/.claude/skills", "~/.codex/skills"],
  "enableSkillCommands": true,
  "lastChangelogVersion": "0.69.0",
  "enableInstallTelemetry": false
}
