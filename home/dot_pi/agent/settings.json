{
  "enabledModels": [
    "sakura/gpt-oss-120b",
    "sakura/Qwen3-Coder-480B-A35B-Instruct-FP8",
    "cloudflare-ai/@cf/moonshotai/kimi-k2.5",
    "cloudflare-ai/@cf/zai-org/glm-4.7-flash",
    "openrouter/openrouter/free",
    "openrouter/moonshotai/kimi-k2.6",
    "openrouter/~anthropic/claude-opus-latest",
    "openrouter/anthropic/claude-sonnet-4.6",
    "anthropic/claude-sonnet-4-6",
    "anthropic/claude-opus-4-7",
    "cursor/auto",
    "cursor/composer-2-fast",
    "cursor/gpt-5.4-medium",
    "cursor/claude-opus-4-7-medium",
    "cursor/claude-4.6-sonnet-medium"
  ],
  "defaultProvider": "cloudflare-ai",
  "defaultModel": "@cf/moonshotai/kimi-k2.5",
  "defaultThinkingLevel": "medium",
  "thinkingBudgets": {
    "minimal": 1024,
    "low": 4096,
    "medium": 10240,
    "high": 32768
  },
  "theme": "monokai",
  "language": "ja",
  "locale": "ja-JP",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "sessionDir": ".pi/sessions",
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "retryDelay": 3000,
    "maxRetryDelay": 60000
  },
  "packages": [
    "pi-skills",
    "npm:pi-subagents",
    "npm:pi-runline",
    "npm:@netandreus/pi-cursor-provider",
    "https://github.com/Eddayy/pi-cloudflare-ai-gateway",
    "https://github.com/bneil/pi-cloudflare-workers-ai"
  ],
  "extensions": [],
  "prompts": [],
  "skills": [
    "~/.claude/skills",
    "~/.codex/skills",
    "~/.gemini/skills",
    "~/.agentskills",
    "~/.aionui-config/skills"
  ],
  "enableSkillCommands": true,
  "lastChangelogVersion": "0.70.2",
  "enableInstallTelemetry": false
}