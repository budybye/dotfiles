{
  "defaultProvider": "cursor",
  "defaultModel": "auto",
  "defaultThinkingLevel": "medium",
  "thinkingBudgets": {
    "minimal": 1024,
    "low": 4096,
    "medium": 10240,
    "high": 32768
  },
  "theme": "monokai",
  "language": "ja",
  "locale": "ja-JP",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "sessionDir": ".pi/sessions",
  "steeringMode": "one-at-a-time",
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "retryDelay": 3000,
    "maxRetryDelay": 60000
  },
  "shellCommandPrefix": "shopt -s expand_aliases\neval \"$(grep '^alias ' ~/.aliases)\"",
  "npmCommand": [
    "bun"
  ],
  "enableSkillCommands": true,
  "lastChangelogVersion": "0.80.10",
  "enableInstallTelemetry": false,
  "packages": [
    "npm:@netandreus/pi-cursor-provider",
    "npm:pi-herdr-squad",
    "npm:@llblab/pi-telegram"
  ],
  "skills": [
    "~/.claude/skills",
    "~/.codex/skills",
    "~/.gemini/skills",
    "~/.agents/skills",
    "~/.aionui-config/skills"
  ],
  "enabledModels": [
    "sakura/gpt-oss-120b",
    "sakura/Qwen3-Coder-480B-A35B-Instruct-FP8",
    "openrouter/openrouter/free",
    "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
    "sensei/google-ai-studio/gemini-3.1-flash-lite",
    "sensei/google-ai-studio/gemini-3.5-flash",
    "opencode-go/glm-5.2",
    "opencode-go/deepseek-v4-flash",
    "opencode-go/kimi-k2.7-code",
    "opencode-go/mimo-v2.5-pro",
    "opencode-zen/nemotron-3-ultra-free",
    "opencode-zen/deepseek-v4-flash-free",
    "opencode-zen/north-mini-code-free",
    "cursor/auto",
    "cloudflare-workers-ai/@cf/zai-org/glm-5.2",
    "cloudflare-workers-ai/@cf/moonshotai/kimi-k2.7-code",
    "cloudflare-ai-gateway/workers-ai/@cf/zai-org/glm-4.7-flash",
    "cloudflare-ai-gateway/workers-ai/@cf/moonshotai/kimi-k2.6"
  ]
}