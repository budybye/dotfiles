{
  "name": "ubuntu-dev",
  // "build.context": ".",
  "dockerComposeFile": "compose.yaml",
  "service": "ubuntu",
  "containerUser": "dev",
  "remoteUser": "dev",
  "workspaceFolder": "/home/dev",
  "forwardPorts": [3389, 22],
  "privileged": true,
  "initializeCommand": "echo 'Dev container initializing...'",
  "onCreateCommand": "echo 'Dev container creating...'",
  "postCreateCommand": "echo 'Dev container post created...'",
  "postStartCommand": "echo 'Dev container post started...'",
  "postAttachCommand": "echo 'Dev container post attached...'",
  "shutdownAction": "stopCompose",
  "remoteEnv": {
    "REMOTE_CONTAINERS": "true",
  },
  "features": {
    "ghcr.io/coder/devcontainer-features/code-server:1": {},
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.tabSize": 4,
        "editor.formatOnSave": true,
        "files.autoSave": "afterDelay",
        "files.autoSaveDelay": 3000,
        "files.exclude": {
          "**/.git": true,
          "**/.DS_Store": true,
        },
        "dotfiles.repository": "budybye/dotfiles",
        "dotfiles.targetPath": "~/dotfiles",
        "dotfiles.installCommand": "~/dotfiles/install.sh",
      },
      "extensions": [
        "adpyke.codesnap",
        "bradlc.vscode-tailwindcss",
        "christian-kohler.path-intellisense",
        "corschenzi.mermaid-graphical-editor",
        "esbenp.prettier-vscode",
        "editorconfig.editorconfig",
        "formulahendry.auto-close-tag",
        "formulahendry.auto-complete-tag",
        "formulahendry.auto-rename-tag",
        "dbaeumer.vscode-eslint",
        "docker.docker",
        "golang.go",
        "jinliming2.vscode-go-template",
        "metaphore.kanagawa-vscode-color-theme",
        "ms-ceintl.vscode-language-pack-ja",
        "ms-python.python",
        "ms-vscode.hexeditor",
        "ms-vscode.makefile-tools",
        "ms-vscode-remote.remote-containers",
        "ms-vscode-remote.remote-ssh-edit",
        "ms-vscode-remote.remote-ssh",
        "ms-vscode-remote.vscode-remote-extensionpack",
        "mtxr.sqltools",
        "naumovs.color-highlight",
        "oderwat.indent-rainbow",
        "redhat.vscode-yaml",
        "stkb.rewrap",
        "tamasfe.even-better-toml",
        "twpayne.vscode-igc",
        "twpayne.vscode-testscript",
        "Tyriar.sort-lines",
        "wallabyjs.console-ninja",
        "yzhang.markdown-all-in-one",
      ],
    },
  },
}
